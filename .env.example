PORT=8080
DATABASE_URL=postgres://app:app@localhost:5432/tsz?sslmode=disable
JWT_SECRET=change-me-use-a-long-random-string-in-production
JWT_TTL=15m
REFRESH_TOKEN_TTL=720h
# Admin (back office) tokens are a SEPARATE identity realm with their OWN signing
# key, so a web token can never pass the admin gate and vice versa (a token signed
# with one key fails verification under the other). Keep ADMIN_JWT_SECRET distinct
# from JWT_SECRET. The admin refresh cookie is scoped to /api/v1/admin. See
# docs/user-module-design.md §4.
ADMIN_JWT_SECRET=change-me-a-DIFFERENT-long-random-string
ADMIN_JWT_TTL=15m
ADMIN_REFRESH_TOKEN_TTL=720h
OTP_CODE_TTL=5m
OTP_RESEND_COOLDOWN=60s
OTP_DAILY_LIMIT=10
# Per-IP throttle on the public /auth/* endpoints: AUTH_RATE_LIMIT_PER_MIN
# sustained requests/min with a short AUTH_RATE_BURST allowance. Rate 0 disables.
AUTH_RATE_LIMIT_PER_MIN=30
AUTH_RATE_BURST=10
APP_ENV=development
# Refresh-token cookies carry the Secure attribute (HTTPS-only). Defaults to
# true outside development. Set false ONLY on a plain-HTTP test host (bare-IP
# before TLS) — browsers drop Secure cookies on http origins, so session
# restore 401s on every reload. NEVER false in production.
# COOKIE_SECURE=false
LOG_LEVEL=info
# Serve Swagger UI at /docs and the OpenAPI spec at /docs/openapi.yaml.
# Set to false to hide the API surface in production.
DOCS_ENABLED=true
# Observability.
# Prometheus metrics at /metrics (set false to disable the endpoint).
METRICS_ENABLED=true
# OTLP/HTTP collector as host:port (e.g. localhost:4318). Empty = tracing off.
TRACING_ENDPOINT=
# Send traces over plain HTTP (no TLS) to the collector.
TRACING_INSECURE=true
# Labels metrics and traces.
SERVICE_NAME=tsz-go
# First super-admin bootstrap (used only by `make seed`, never by the server).
# Admin is not self-registerable, so the first back-office account — a super_admin,
# who then creates the rest from the console — is created out of band into the
# `admins` table. Local / first-run only — DO NOT commit real values.
# SEED_ADMIN_DISPLAY_NAME is optional (defaults to "Administrator").
SEED_ADMIN_PHONE=13800138000
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_ADMIN_DISPLAY_NAME=Administrator
